# =============================================
# OfferU - 环境变量模板
# =============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# =============================================

# ---- 数据库 ----
DB_USER=offeru
DB_PASSWORD=offeru_secret
DB_NAME=offeru

# ---- API Keys ----
OPENAI_API_KEY=sk-your-openai-key-here
APIFY_API_KEY=your-apify-key-here

# ---- 安全 ----
SECRET_KEY=change-me-to-a-random-string-in-production

# ---- Gmail OAuth (邮件面试通知) ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# ---- 前端跨域 ----
CORS_ORIGINS=http://localhost:3000

# ---- 数据库连接串（后端用，Docker 模式自动拼接） ----
DATABASE_URL=sqlite+aiosqlite:///./offeru.db
