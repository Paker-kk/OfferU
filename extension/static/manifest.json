{
  "manifest_version": 3,
  "name": "OfferU 岗位采集助手",
  "version": "0.1.0",
  "description": "从 Boss直聘等招聘平台一键采集岗位信息到 OfferU 系统",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.zhipin.com/*"
      ],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ]
}
